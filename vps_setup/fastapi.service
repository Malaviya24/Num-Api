[Unit]
Description=FastAPI application for Customer Search API
After=network.target

[Service]
User=root
Group=root
WorkingDirectory=/opt/customer_search_api/backend
Environment="PATH=/opt/customer_search_api/venv/bin"
EnvironmentFile=/opt/customer_search_api/backend/.env
ExecStart=/opt/customer_search_api/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 4

[Install]
WantedBy=multi-user.target
